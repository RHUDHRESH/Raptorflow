{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "pnpm --filter @raptorflow/web build",
  "installCommand": "pnpm install --frozen-lockfile",
  "devCommand": "pnpm --filter @raptorflow/web dev",
  "regions": ["sin1"],
  "env": {
    "NEXT_PUBLIC_APP_URL": "@rf_app_url",
    "NEXT_PUBLIC_API_BASE_URL": "@rf_api_base_url",
    "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY": "@rf_clerk_publishable_key",
    "NEXT_PUBLIC_OFFLINE_MODE": "false"
  },
  "headers": [
    {
      "source": "/api/health",
      "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
    },
    {
      "source": "/api/v1/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/proxy/(.*)",
      "destination": "https://api.raptorflow.io/$1",
      "password": "@vercel_proxy_password"
    }
  ]
}
