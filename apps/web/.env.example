# Frontend environment variables for RaptorFlow.
# Copy this to apps/web/.env.local and fill in your values.
# apps/web/.env.local is gitignored — never commit secrets.

# =============================================================================
# REQUIRED — fill in before running
# =============================================================================

# Clerk publishable key — get from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here

# =============================================================================
# OPTIONAL — defaults work for local development
# =============================================================================

# Where the frontend runs
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Where the API runs (change to https://api.staging.raptorflow.io for staging)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Set to "true" to use mock data instead of the real backend
# No backend, no GCP credentials, no problem — everything works offline
NEXT_PUBLIC_OFFLINE_MODE=false

# Application environment: "dev" | "staging" | "prod"
# Controls debug tools visibility, CORS settings, and feature flags
NEXT_PUBLIC_APP_ENV=dev
