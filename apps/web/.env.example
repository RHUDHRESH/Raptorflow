# Frontend environment variables for RaptorFlow.
# Copy this to apps/web/.env.local and fill in your values.
# apps/web/.env.local is gitignored — never commit secrets.

# =============================================================================
# REQUIRED — fill in before running
# =============================================================================

# Clerk publishable key — get from https://dashboard.clerk.com
# Example: pk_test_a1b2c3d4e5f6...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Clerk secret key (server-side only) — get from https://dashboard.clerk.com
# Example: sk_test_a1b2c3d4e5f6...
CLERK_SECRET_KEY=

# AI inference — AWS Bedrock
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_STRATEGIST=mistral.mistral-large-3-675b-instruct
BEDROCK_MODEL_FAST=mistral.ministral-3-8b-instruct

# =============================================================================
# OPTIONAL — defaults work for local development
# =============================================================================

# Where the frontend runs
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Where the API runs (change to https://api.staging.raptorflow.io for staging)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Application environment: "dev" | "staging" | "prod"
NEXT_PUBLIC_APP_ENV=dev

# Secret required by scheduled Next.js cron routes.
CRON_SECRET=

# Sentry
NEXT_PUBLIC_SENTRY_DSN=
RAPTORFLOW_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=raptorflow
SENTRY_PROJECT=javascript-nextjs
# Set to 1 only when you intentionally want local builds to upload source maps.
SENTRY_UPLOAD_SOURCE_MAPS=0
