{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raptorflow.dev/schemas/ws/session-events.json",
  "title": "SessionStreamEvent",
  "type": "object",
  "required": ["type", "session_id", "org_id", "timestamp"],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "session.started",
        "session.progress",
        "session.stream",
        "session.completed",
        "session.reconnect"
      ]
    },
    "session_id": {
      "type": "string"
    },
    "org_id": {
      "type": "string",
      "format": "uuid"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
