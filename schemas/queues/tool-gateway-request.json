{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raptorflow.dev/schemas/queues/tool-gateway-request.json",
  "title": "ToolGatewayRequestEnvelope",
  "type": "object",
  "required": [
    "job_type",
    "org_id",
    "request_id",
    "tool_name",
    "arguments",
    "timeout_ms",
    "enqueued_at"
  ],
  "properties": {
    "job_type": {
      "const": "tool.gateway"
    },
    "org_id": {
      "type": "string",
      "format": "uuid"
    },
    "request_id": {
      "type": "string"
    },
    "session_id": {
      "type": "string"
    },
    "tool_name": {
      "type": "string"
    },
    "arguments": {
      "type": "object",
      "additionalProperties": true
    },
    "timeout_ms": {
      "type": "integer",
      "minimum": 1
    },
    "enqueued_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
