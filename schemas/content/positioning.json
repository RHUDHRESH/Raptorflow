{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raptorflow.dev/schemas/content/positioning.json",
  "title": "Positioning",
  "description": "Positioning statements, taglines, and proof requirements",
  "type": "object",
  "required": ["positioning_statements"],
  "properties": {
    "positioning_statements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["statement", "variant"],
        "properties": {
          "statement": { "type": "string", "minLength": 10 },
          "variant": { "type": "string", "enum": ["primary", "secondary", "alt", "short"] }
        }
      }
    },
    "tagline_options": {
      "type": "array",
      "items": { "type": "string", "minLength": 3 }
    },
    "proof_requirements": {
      "type": "array",
      "items": { "type": "string", "minLength": 5 }
    },
    "learnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
