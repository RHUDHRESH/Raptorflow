{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raptorflow.dev/schemas/content/hook-set.json",
  "title": "HookSet",
  "description": "Generated copy hooks for ads, emails, or content",
  "type": "object",
  "required": ["hooks", "winning_angles"],
  "properties": {
    "hooks": {
      "type": "array",
      "minItems": 1,
      "maxItems": 30,
      "items": {
        "type": "object",
        "required": ["text", "type"],
        "properties": {
          "text": { "type": "string", "minLength": 5, "maxLength": 500 },
          "type": { "type": "string", "enum": ["hook", "angle", "question", "stat", "story"] },
          "angle": { "type": "string" },
          "salience": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "winning_angles": {
      "type": "array",
      "items": { "type": "string", "minLength": 5 }
    },
    "proof_gaps": {
      "type": "array",
      "items": { "type": "string" }
    },
    "learnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
