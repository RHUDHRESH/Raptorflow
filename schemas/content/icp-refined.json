{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raptorflow.dev/schemas/content/icp-refined.json",
  "title": "IcpRefined",
  "description": "Refined Ideal Customer Profile with demographics, psychographics, and pain points",
  "type": "object",
  "required": ["refined_icp", "confidence"],
  "properties": {
    "refined_icp": {
      "type": "object",
      "required": ["demographics", "psychographics", "pain_points"],
      "properties": {
        "demographics": {
          "type": "object",
          "properties": {
            "role": { "type": "string" },
            "industry": { "type": "string" },
            "company_size": { "type": "string" },
            "seniority": { "type": "string" }
          }
        },
        "psychographics": {
          "type": "object",
          "required": ["values", "fears", "aspirations"],
          "properties": {
            "values": { "type": "array", "items": { "type": "string" } },
            "fears": { "type": "array", "items": { "type": "string" } },
            "aspirations": { "type": "array", "items": { "type": "string" } }
          }
        },
        "behaviors": {
          "type": "object",
          "properties": {
            "content_consumption": { "type": "array", "items": { "type": "string" } },
            "purchase_patterns": { "type": "array", "items": { "type": "string" } }
          }
        },
        "pain_points": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 5 }
        }
      }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "learnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
