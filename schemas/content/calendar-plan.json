{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raptorflow.dev/schemas/content/calendar-plan.json",
  "title": "CalendarPlan",
  "description": "Content calendar with weekly schedules, themes, and coverage analysis",
  "type": "object",
  "required": ["calendar", "themes"],
  "properties": {
    "calendar": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["week", "content_type", "platform", "topic"],
        "properties": {
          "week": { "type": "integer", "minimum": 1, "maximum": 52 },
          "date": { "type": "string", "format": "date" },
          "content_type": { "type": "string", "enum": ["blog", "social", "email", "video", "podcast", "webinar"] },
          "platform": { "type": "string", "minLength": 2 },
          "topic": { "type": "string", "minLength": 5 },
          "angle": { "type": "string" },
          "call_to_action": { "type": "string" }
        }
      }
    },
    "themes": {
      "type": "array",
      "items": { "type": "string", "minLength": 5 }
    },
    "coverage_analysis": {
      "type": "object",
      "properties": {
        "platform_coverage": { "type": "object" },
        "content_type_coverage": { "type": "object" },
        "gaps": { "type": "array", "items": { "type": "string" } }
      }
    },
    "learnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
