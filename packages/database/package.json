{
  "name": "@raptorflow/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./index.js",
      "require": "./require.cjs",
      "default": "./index.js"
    }
  },
  "scripts": {
    "generate": "prisma generate",
    "migrate": "prisma migrate dev",
    "migrate:status": "prisma migrate status",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "pg": "8.20.0"
  },
  "devDependencies": {
    "@types/pg": "8.20.0",
    "dotenv": "17.4.2",
    "prisma": "7.8.0",
    "typescript": "6.0.2"
  }
}
