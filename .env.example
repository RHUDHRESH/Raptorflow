# ============================================================
# RAPTORFLOW — Environment Template (Frontend + Backend)
# ============================================================
# Copy to `.env.local` for Next.js frontend.
# Backend env lives in `backend/.env` (see backend/.env.example).

# --- Frontend (Next.js) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# --- Supabase (shared between frontend + backend) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# --- Authentication ---
# Options: demo, supabase, disabled
# - demo: Local development mode (any credentials work)
# - supabase: Real Supabase email/password auth (RECOMMENDED for production)
# - disabled: No auth (INSECURE - only for testing)
AUTH_MODE=supabase

# --- Session Settings (optional) ---
# ACCESS_TOKEN_EXPIRY=3600      # Access token lifetime in seconds (default: 1 hour)
# REFRESH_TOKEN_EXPIRY=604800   # Refresh token lifetime in seconds (default: 7 days)

# --- Sentry (Frontend Monitoring) ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
