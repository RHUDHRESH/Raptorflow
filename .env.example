# =============================================================================
# Shared environment scaffold
# Copy this file to .env and fill in real values. Never commit real secrets.
# =============================================================================
NODE_ENV=development
APP_ENV=dev
AWS_REGION=ap-south-1
VERCEL_PROJECT_ID=replace-me
VERCEL_ORG_ID=replace-me

# =============================================================================
# Frontend — Clerk auth (REQUIRED)
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# =============================================================================
# Backend
# =============================================================================
RAPTORFLOW_BIND_ADDR=0.0.0.0:8080
RAPTORFLOW_FRONTEND_URL=http://localhost:3000
RAPTORFLOW_DATABASE_URL=
RAPTORFLOW_DIRECT_DATABASE_URL=
RAPTORFLOW_DRAGONFLY_URL=redis://localhost:6379
RAPTORFLOW_QDRANT_URL=http://localhost:6333
RAPTORFLOW_S3_BUCKET=raptorflow-dev
RAPTORFLOW_SQS_BASE_URL=
RAPTORFLOW_SQS_EMBEDDING_QUEUE=raptorflow-dev-embedding
RAPTORFLOW_SQS_CONTENT_QUEUE=raptorflow-dev-content-pregeneration

# AI Inference — AWS Bedrock (IAM auth, no API key needed)
RAPTORFLOW_BEDROCK_REGION=ap-south-1
RAPTORFLOW_BEDROCK_MODEL_STRATEGIST=mistral.mistral-large-3-675b-instruct
RAPTORFLOW_BEDROCK_MODEL_FAST=mistral.mistral-7b-instruct-v0:2
RAPTORFLOW_GCP_API_KEY=

# Clerk verification (REQUIRED)
RAPTORFLOW_CLERK_JWKS_URL=
RAPTORFLOW_CLERK_ISSUER=
RAPTORFLOW_CLERK_AUDIENCE=
RAPTORFLOW_CLERK_WEBHOOK_SECRET=
RAPTORFLOW_ALLOW_INSECURE_DEV_AUTH=true
RAPTORFLOW_DEV_BEARER_TOKEN=raptorflow-dev-token

# Payments (Razorpay — NOT Clerk)
RAPTORFLOW_RAZORPAY_KEY_ID=replace-me
RAPTORFLOW_RAZORPAY_KEY_SECRET=replace-me
RAPTORFLOW_RAZORPAY_WEBHOOK_SECRET=razorpay-dev-shared-secret
RAPTORFLOW_WEBHOOK_TIMESTAMP_TOLERANCE_SECONDS=300

# Email (Resend)
RAPTORFLOW_RESEND_API_KEY=replace-me
RAPTORFLOW_RESEND_FROM_EMAIL=onboarding@resend.dev
RAPTORFLOW_RESEND_WEBHOOK_SECRET=whsec_dev_resend_replace_me

RAPTORFLOW_SENTRY_DSN=
SENTRY_DSN=