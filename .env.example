# RAPTORFLOW CORE ENVIRONMENT CONFIGURATION (2026)
=======
# RAPTORFLOW — SINGLE SOURCE OF TRUTH FOR ENVIRONMENT VARIABLES
# =================================================================
# Copy this file to .env.local (Next.js) or .env (backend).
# See ADRs/ADR-0003-env-consolidation.md for rationale.
#
# Legend:
#   [FE]  = consumed by Next.js (browser or server-side)
#   [BE]  = consumed by FastAPI backend (backend/config/settings.py)
#   [BOTH]= consumed by both layers
>>>>>>> C:/Users/hp/.windsurf/worktrees/Raptorflow/Raptorflow-ff539c12/.env.example
# =================================================================

# --- Environment & App URLs ---
NODE_ENV=development                                          # [FE]
ENVIRONMENT=development                                       # [BE] dev | staging | production
DEBUG=true                                                    # [BE]
NEXT_PUBLIC_APP_URL=http://localhost:3000                      # [FE] canonical frontend origin
NEXT_PUBLIC_API_URL=http://localhost:8000                      # [FE] backend base URL (used by proxy & direct calls)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000                  # [FE] alias — kept for backward compat; prefer NEXT_PUBLIC_API_URL
BACKEND_API_URL=http://localhost:8000                          # [FE] server-side only; proxy route reads this first

# --- Supabase (Auth, Database, Storage) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co     # [BOTH]
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key          # [BOTH]
SUPABASE_URL=https://YOUR_PROJECT.supabase.co                 # [BE] backend uses this (same value as NEXT_PUBLIC_SUPABASE_URL)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key       # [BE] admin operations — NEVER expose to browser
SUPABASE_JWT_SECRET=your_supabase_jwt_secret                  # [BE] JWT verification in auth middleware

# --- Google Cloud Platform (Vertex AI & GCS) ---
GCP_PROJECT_ID=your_gcp_project_id                            # [BE]
GCP_REGION=us-central1                                        # [BE]
GOOGLE_APPLICATION_CREDENTIALS=./raptorflow-storage-key.json  # [BE] path to service-account JSON
VERTEX_AI_PROJECT_ID=your_gcp_project_id                      # [BE] alias for GCP_PROJECT_ID (Vertex AI SDK)
VERTEX_AI_LOCATION=us-central1                                # [BE]
VERTEX_AI_API_KEY=                                            # [BE] optional — used when ADC is unavailable
GCS_BUCKET_NAME=raptorflow-uploads                            # [BE]
GCS_CDN_URL=https://storage.googleapis.com/raptorflow-uploads # [FE]

# --- Upstash Redis (Caching & Rate Limiting) ---
UPSTASH_REDIS_REST_URL=https://YOUR_ENDPOINT.upstash.io       # [BOTH] REST API
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token              # [BOTH]
UPSTASH_REDIS_URL=https://YOUR_ENDPOINT.upstash.io            # [BE] alias used by some backend modules
UPSTASH_REDIS_TOKEN=your_upstash_token                        # [BE]
REDIS_URL=redis://localhost:6379                              # [BE] fallback for local dev (redis:// or rediss://)

# --- Resend (Email Service) ---
RESEND_API_KEY=re_your_api_key                                # [BE]
RESEND_FROM_EMAIL=onboarding@resend.dev                       # [BE]
RESEND_VERIFIED_EMAIL=your_verified_email@gmail.com           # [BE]

# --- PhonePe Payment Gateway (2026 Standard Checkout API) ---
PHONEPE_CLIENT_ID=your_client_id                              # [FE] server-side route handler
PHONEPE_CLIENT_SECRET=your_client_secret                      # [FE] server-side route handler — NEVER expose to browser
PHONEPE_MERCHANT_ID=MERCHANTXXXXXX                            # [FE]
PHONEPE_ENV=UAT                                               # [FE] UAT | PRODUCTION
PHONEPE_CLIENT_VERSION=1                                      # [FE]
PHONEPE_WEBHOOK_USERNAME=your_webhook_username                 # [FE]
PHONEPE_WEBHOOK_PASSWORD=your_webhook_password                 # [FE]
PHONEPE_SUCCESS_URL=http://localhost:3000/onboarding/payment/status  # [FE]
PHONEPE_CALLBACK_URL=http://localhost:3000/api/webhooks/phonepe     # [FE]

# --- Sentry (Monitoring & Error Tracking) ---
SENTRY_DSN=your_sentry_dsn                                    # [BOTH]
SENTRY_ENVIRONMENT=development                                # [BOTH]
SENTRY_AUTH_TOKEN=your_sentry_auth_token                      # [FE] build-time source-map upload

# --- Search & Scraper ---
BRAVE_SEARCH_API_KEY=                                         # [BE] optional
SERPER_API_KEY=                                               # [BE] optional
SEARXNG_URL=http://localhost:8080                              # [BE] local SearXNG instance

# --- Internal / Service-to-Service ---
INTERNAL_API_TOKEN=                                           # [BOTH] Next middleware → backend header auth
RF_INTERNAL_KEY=                                              # [BE] deep health-check gating
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000000        # [BE]

# --- Backend Feature Flags ---
ENABLE_LEGACY_V1=false                                        # [BE] mount legacy /api/v1 prefix
ENABLE_LEGACY_API_PATHS=true                                  # [BE] rewrite /api/v1/* → /api/*
ENABLE_LEGACY_EXPERIMENTAL_ROUTES=false                       # [BE]

# --- Deprecated (do NOT use — kept for reference only) ---
# PHONEPE_SALT_KEY=deprecated
# PHONEPE_SALT_INDEX=deprecated
# SMTP_USER=deprecated_in_favor_of_resend
# SMTP_PASS=deprecated_in_favor_of_resend
# NEXTAUTH_SECRET=deprecated_supabase_handles_auth
# NEXTAUTH_URL=deprecated
