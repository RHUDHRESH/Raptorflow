# =============================================================================
# Shared environment scaffold
# Copy this file to .env and fill in real values. Never commit real secrets.
# =============================================================================
NODE_ENV=development
APP_ENV=dev
AWS_REGION=ap-south-1
VERCEL_PROJECT_ID=replace-me
VERCEL_ORG_ID=replace-me

# =============================================================================
# Frontend — Clerk auth (REQUIRED)
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
CLERK_SECRET_KEY=

# =============================================================================
# Backend
# =============================================================================
RAPTORFLOW_BIND_ADDR=0.0.0.0:8080
RAPTORFLOW_FRONTEND_URL=http://localhost:3000
RAPTORFLOW_DATABASE_URL=postgresql://raptorflow:raptorflow@localhost:5432/raptorflow?schema=public
RAPTORFLOW_DIRECT_DATABASE_URL=postgresql://raptorflow:raptorflow@localhost:5432/raptorflow?schema=public
RAPTORFLOW_QDRANT_URL=http://localhost:6333
RAPTORFLOW_QDRANT_API_KEY=
RAPTORFLOW_S3_BUCKET=raptorflow-dev
RAPTORFLOW_SQS_BASE_URL=https://sqs.ap-south-1.amazonaws.com
RAPTORFLOW_SQS_EMBEDDING_QUEUE=raptorflow-dev-embedding
RAPTORFLOW_SQS_CONTENT_QUEUE=raptorflow-dev-content-pregeneration

# Rust Backend DB
RAPTORFLOW_DATABASE_URL=postgres://raptorflow:raptorflow@localhost:6432/raptorflow
RAPTORFLOW_DIRECT_DATABASE_URL=postgres://raptorflow:raptorflow@localhost:5432/raptorflow

# AI Inference — AWS Bedrock (IAM auth, no API key needed)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_STRATEGIST=mistral.mistral-large-3-675b-instruct
BEDROCK_MODEL_FAST=mistral.ministral-3-8b-instruct
RAPTORFLOW_BEDROCK_REGION=ap-south-1
RAPTORFLOW_BEDROCK_MODEL_STRATEGIST=mistral.mistral-large-3-675b-instruct
RAPTORFLOW_BEDROCK_MODEL_FAST=mistral.ministral-3-8b-instruct

# Prisma (for TypeScript packages)
DATABASE_URL=postgresql://raptorflow:raptorflow@localhost:5432/raptorflow?schema=public
DIRECT_DATABASE_URL=postgresql://raptorflow:raptorflow@localhost:5432/raptorflow?schema=public
PRISMA_ACCELERATE_URL=
PRISMA_PULSE_API_KEY=

# Clerk verification (REQUIRED)
RAPTORFLOW_CLERK_JWKS_URL=
RAPTORFLOW_CLERK_ISSUER=
RAPTORFLOW_CLERK_AUDIENCE=
RAPTORFLOW_CLERK_WEBHOOK_SECRET=

# Payments (Razorpay — NOT Clerk)
RAPTORFLOW_RAZORPAY_KEY_ID=replace-me
RAPTORFLOW_RAZORPAY_KEY_SECRET=replace-me
RAPTORFLOW_RAZORPAY_WEBHOOK_SECRET=razorpay-dev-shared-secret
RAPTORFLOW_WEBHOOK_TIMESTAMP_TOLERANCE_SECONDS=300

# Email (Resend)
RAPTORFLOW_RESEND_API_KEY=replace-me
RAPTORFLOW_RESEND_FROM_EMAIL=onboarding@resend.dev
RAPTORFLOW_RESEND_WEBHOOK_SECRET=whsec_dev_resend_replace_me

# Sentry
NEXT_PUBLIC_SENTRY_DSN=
RAPTORFLOW_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=raptorflow
SENTRY_PROJECT=javascript-nextjs
