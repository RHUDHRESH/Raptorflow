# =============================================================================
# RaptorFlow environment scaffold
# Copy to .env for local development. Never commit real secrets.
# =============================================================================

# App identity
NODE_ENV=development
APP_ENV=dev
AWS_REGION=ap-south-1
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
RAPTORFLOW_FRONTEND_URL=http://localhost:3000
RAPTORFLOW_BIND_ADDR=0.0.0.0:8080

# Clerk auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
CLERK_SECRET_KEY=
RAPTORFLOW_CLERK_JWKS_URL=
RAPTORFLOW_CLERK_ISSUER=
RAPTORFLOW_CLERK_AUDIENCE=
RAPTORFLOW_CLERK_WEBHOOK_SECRET=

# Rust API database runtime
# API runtime should use PgBouncer. Migrations and seeds must use the direct URL.
RAPTORFLOW_DATABASE_URL=postgres://raptorflow:raptorflow@localhost:6432/raptorflow
RAPTORFLOW_DIRECT_DATABASE_URL=postgres://raptorflow:raptorflow@localhost:5432/raptorflow

# Prisma TypeScript tooling
# Prisma CLI/client uses these names only inside packages/database and Next.js API routes.
DATABASE_URL=postgres://raptorflow:raptorflow@localhost:5432/raptorflow
DIRECT_DATABASE_URL=postgres://raptorflow:raptorflow@localhost:5432/raptorflow

# Vector memory
RAPTORFLOW_QDRANT_URL=http://localhost:6333
RAPTORFLOW_QDRANT_API_KEY=
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# AWS Bedrock inference
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
RAPTORFLOW_BEDROCK_REGION=ap-south-1
RAPTORFLOW_BEDROCK_MODEL_STRATEGIST=mistral.mistral-large-3-675b-instruct
RAPTORFLOW_BEDROCK_MODEL_FAST=mistral.ministral-3-8b-instruct

# AWS storage and queues
RAPTORFLOW_S3_BUCKET=raptorflow-dev
RAPTORFLOW_SQS_BASE_URL=https://sqs.ap-south-1.amazonaws.com
RAPTORFLOW_SQS_EMBEDDING_QUEUE=raptorflow-dev-embedding
RAPTORFLOW_SQS_CONTENT_QUEUE=raptorflow-dev-content-pregeneration

# Razorpay billing
RAPTORFLOW_RAZORPAY_KEY_ID=
RAPTORFLOW_RAZORPAY_KEY_SECRET=
RAPTORFLOW_RAZORPAY_WEBHOOK_SECRET=
RAPTORFLOW_WEBHOOK_TIMESTAMP_TOLERANCE_SECONDS=300

# Email
RAPTORFLOW_RESEND_API_KEY=
RAPTORFLOW_RESEND_FROM_EMAIL=onboarding@resend.dev
RAPTORFLOW_RESEND_WEBHOOK_SECRET=

# Scheduled routes
CRON_SECRET=

# Observability
NEXT_PUBLIC_SENTRY_DSN=
RAPTORFLOW_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=raptorflow
SENTRY_PROJECT=javascript-nextjs
# Set to 1 only when you intentionally want local builds to upload source maps.
SENTRY_UPLOAD_SOURCE_MAPS=0
VERCEL_PROJECT_ID=
VERCEL_ORG_ID=
